# ============================================================
# EuroLeague Analytics - Environment variables
# ============================================================
# Copier ce fichier en .env.local pour le développement.
# En prod, les variables sont définies dans Vercel.

# --- DuckDB ---
# Chemin vers le fichier DuckDB utilisé par les API routes.
# En local : public/data/euroleague.duckdb (généré par bootstrap_demo_db.py)
# En prod : même chemin, alimenté via la branche data du repo.
DUCKDB_PATH=public/data/euroleague.duckdb

# --- Page admin ---
# Hash bcrypt du mot de passe admin (jamais en clair).
# Génération : python -c "import bcrypt; print(bcrypt.hashpw(b'monMotDePasse', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# Clé aléatoire pour signer les cookies admin (openssl rand -hex 32)
ADMIN_SESSION_SECRET=

# --- GitHub Actions (refresh manuel depuis page admin) ---
# Token GitHub avec scopes repo + workflow (fine-grained recommandé)
# Crée sur https://github.com/settings/tokens
GITHUB_REFRESH_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=euroleague-analytics
GITHUB_WORKFLOW_FILE=refresh.yml

# --- Divers ---
# Niveau de log : debug | info | warn | error
LOG_LEVEL=info
